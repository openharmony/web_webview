import("//base/web/webview/web_aafwk.gni")
import("//build/test.gni")

module_output_path = "webview/webview"

config("module_private_config") {
  visibility = [ ":*" ]

  include_dirs = [
    "$webview_path/ohos_adapter/interfaces",
    "$webview_path/ohos_adapter/background_task_adapter/include",
  ]
}

ohos_unittest("background_task_impl_test") {
  module_out_path = module_output_path

  sources = [ "background_task_impl_test.cpp" ]

  configs = [ ":module_private_config" ]

  deps = [ "$webview_path/ohos_adapter:nweb_ohos_adapter" ]

  external_deps = [
    "ability_runtime:wantagent_innerkits",
    "ability_runtime:ability_connect_callback_stub",
    "background_task_mgr:bgtaskmgr_innerkits",
    "c_utils:utils",
    "googletest:gmock_main",
    "googletest:gtest_main",
    "hilog:libhilog",
  ]
}

group("unittest") {
  testonly = true
  deps = [ ":background_task_impl_test" ]
}
